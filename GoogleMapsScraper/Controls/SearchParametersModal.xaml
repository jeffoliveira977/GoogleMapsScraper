<UserControl x:Class="GoogleMapsScraper.Controls.SearchBusinessPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GoogleMapsScraper.Controls" 
             xmlns:viewmodel="clr-namespace:GoogleMapsScraper.ViewModel" 
             xmlns:converters="clr-namespace:GoogleMapsScraper.Converters"
             d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    
    <Grid
      x:Name="modalOverlay"
      Background="#80000000"
      SnapsToDevicePixels="True"
      UseLayoutRounding="True"
      Visibility="{Binding IsModalVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border
          Width="480"
          MaxHeight="540"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Background="White"
          BorderBrush="#D0D0D0"
          BorderThickness="1"
          CornerRadius="12"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True">
            <Grid
              Margin="25"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,20">

                    <TextBlock
                      HorizontalAlignment="Center"
                      FontSize="18"
                      FontWeight="SemiBold"
                      Foreground="#1A1A1A"
                      Text="Parâmetros de Busca" />

                    <Button
                      Width="20"
                      Height="20"
                      Padding="0"
                      HorizontalAlignment="Right"
                      Background="Transparent"
                      BorderThickness="0"
                      Click="CloseModal_Click"
                      Cursor="Hand">
                        <Path Data="{StaticResource CloseIconGeometry}" Style="{StaticResource DefaultIcon}" />
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E5E5E5" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                <ScrollViewer
                  Grid.Row="1"
                  Margin="0,0,-12,0"
                  Padding="0,0,12,0"
                  UseLayoutRounding="True"
                  VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,18">
                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                <Path Data="{StaticResource TagIconGeometry}" Style="{StaticResource DefaultIcon}" />
                                <TextBlock
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Foreground="#1A1A1A"
                                  Text="Categoria" />
                                <TextBlock
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Foreground="#E74C3C"
                                  Text=" *" />
                            </StackPanel>
                            <TextBox
                              x:Name="txtModalSearchTerms"
                              Height="85"
                              FontSize="13"
                              Foreground="#666666"
                              Style="{StaticResource MultiLineTextBox}"
                              Text="{Binding SearchTermsInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,18">
                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                <Path Data="{StaticResource MapMarkerIconGeometry}" Style="{StaticResource DefaultIcon}" />
                                <TextBlock
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Foreground="#1A1A1A"
                                  Text="Localização" />
                                <TextBlock
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Foreground="#E74C3C"
                                  Text=" *" />
                            </StackPanel>
                            <TextBox
                              x:Name="txtModalLocation"
                              FontSize="13"
                              Foreground="#666666"
                              Style="{StaticResource ModernTextBox}"
                              Text="{Binding LocationInput, UpdateSourceTrigger=PropertyChanged}"
                              />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,0">
                            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                                <Path Data="{StaticResource FileUploadIconGeometry}" Style="{StaticResource DefaultIcon}" />
                                <TextBlock
                                  FontSize="13"
                                  FontWeight="SemiBold"
                                  Foreground="#1A1A1A"
                                  Text="Ou Carregar Arquivo" />
                            </StackPanel>
                            <Border
                              Height="90"
                              Background="#FAFAFA"
                              BorderBrush="#D0D0D0"
                              BorderThickness="1.5"
                              CornerRadius="8"
                              UseLayoutRounding="True">
                                <Button
                                  x:Name="btnUploadFile"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Click="BtnUploadFile_Click"
                                  Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Background="Transparent">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Path Data="{StaticResource UploadIconGeometry}" Style="{StaticResource DefaultIcon}" />
                                                    <TextBlock
                                                      HorizontalAlignment="Center"
                                                      FontSize="12"
                                                      Foreground="#666666"
                                                      Text="Clique para carregar .txt" />
                                                </StackPanel>
                                            </Grid>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Border>
                            <TextBlock
                              x:Name="txtFileName"
                              Margin="0,6,0,0"
                              FontSize="11"
                              Foreground="#666666"
                              Text=""
                              TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <Button
                      Height="42"
                      HorizontalAlignment="Stretch"
                      Command="{Binding StartExtractionCommand}"
                      FontSize="14"
                      Style="{StaticResource PrimaryButton}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="Iniciar Extração" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
