<UserControl x:Class="GoogleMapsScraper.Controls.PlaywrightInstallPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GoogleMapsScraper.Controls"
             xmlns:converters="clr-namespace:GoogleMapsScraper.Converters" 
             xmlns:vm="clr-namespace:GoogleMapsScraper.ViewModel" 
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <Style x:Key="IconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="#3B82F6"/>
            <Setter Property="Data" Value="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,9V11H13V9H11M11,13V17H13V13H11Z"/>

            <Style.Triggers>

                <DataTrigger Binding="{Binding CurrentPopupState}" Value="{x:Static vm:PopupStateType.Success}">
                    <Setter Property="Fill" Value="#22C55E" />
                    <Setter Property="Data" Value="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,16.5L6.5,12L7.91,10.59L11,13.67L16.59,8.09L18,9.5L11,16.5Z" />
                </DataTrigger>

                <DataTrigger Binding="{Binding CurrentPopupState}" Value="{x:Static vm:PopupStateType.Error}">
                    <Setter Property="Fill" Value="#EF4444" />
                    <Setter Property="Data" Value="M12,2C17.53,2 22,6.47 22,12C22,17.53 17.53,22 12,22C6.47,22 2,17.53 2,12C2,6.47 6.47,2 12,2M15.59,7L12,10.59L8.41,7L7,8.41L10.59,12L7,15.59L8.41,17L12,13.41L15.59,17L17,15.59L13.41,12L17,8.41L15.59,7Z" />
                </DataTrigger>

            </Style.Triggers>
        </Style>

        <Style x:Key="IconBackgroundStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#F0F9FF"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentPopupState}" Value="{x:Static vm:PopupStateType.Success}">
                    <Setter Property="Fill" Value="#F0FDF4" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentPopupState}" Value="{x:Static vm:PopupStateType.Error}">
                    <Setter Property="Fill" Value="#FEF2F2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid
   Background="#80000000"
   Panel.ZIndex="1000"
   Visibility="{Binding IsPopupVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border Background="White"
         CornerRadius="12"
         MaxWidth="450"
         Padding="32"
         VerticalAlignment="Center"
         HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" 
                           Opacity="0.2" 
                           BlurRadius="20" 
                           ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>

                <Grid Width="64" Height="64" Margin="0,0,0,24" HorizontalAlignment="Center">
                    <Ellipse x:Name="IconBackground" Fill="#F0F9FF"/>
                    <Path x:Name="PopupIconPath"
                   Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,9V11H13V9H11M11,13V17H13V13H11Z"
                   Fill="#3B82F6"
                   Stretch="Uniform"
                   Width="32"
                   Height="32"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="PopupIconRotation" Angle="0"/>
                        </Path.RenderTransform>
                    </Path>
                </Grid>

                <TextBlock x:Name="PopupTitleText"
                    Text="{Binding PopupTitle}"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="#1F2937"
                    TextAlignment="Center"
                    Margin="0,0,0,12"/>

                <TextBlock x:Name="PopupMessageText"
                    Text="{Binding PopupMessage}"
                    FontSize="14"
                    Foreground="#6B7280"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    LineHeight="20"
                    Margin="0,0,0,24"/>

                <ProgressBar x:Name="PopupProgressBar"
                    Height="4"
                    IsIndeterminate="True"
                    
                    Visibility="{Binding IsProgressVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    
                    Margin="0,0,0,24"
                    Foreground="#3B82F6"
                    Background="#E5E7EB"
                    BorderThickness="0"/>

                <Button x:Name="PopupOkButton"
                 Content="OK"
                 Click="PopupOkButton_Click"
                 Height="40"
                 FontSize="14"
                 FontWeight="Medium"
                 Cursor="Hand"
                 Visibility="{Binding IsButtonVisible, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"
                    
                   
                        >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3B82F6"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                         CornerRadius="8"
                                         Padding="24,0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
