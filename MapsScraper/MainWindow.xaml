<Window x:Class="MapsScraper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF" xmlns:local="clr-namespace:MapsScraper.Converters"
        Title="Google Maps Scraper" 
        Height="750" Width="1100"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Modern TextBox Style -->
        <Style TargetType="TextBox" x:Key="ModernTextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#0066CC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#0066CC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#B0B0B0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MultiLine TextBox Style -->
        <Style TargetType="TextBox" x:Key="MultiLineTextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- Modern Button Style -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#5B7C99"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6B8CA9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#D0D0D0"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Icon Style -->
        <Style TargetType="TextBlock" x:Key="IconStyle">
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="icons:MaterialIcon" x:Key="DefaultMaterialIcon">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="#5B7C99"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        
        <Grid Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Border Grid.Row="0" 
                    Background="White" 
                    Padding="30,25"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Google Maps Scraper" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="Extraia dados de estabelecimentos do Google Maps" 
                                   FontSize="14" 
                                   Foreground="#666666"/>
                    </StackPanel>
                    <Button Content="Nova Busca" 
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right"
                            Click="BtnNewSearch_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="30" x:Name="CardsGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="CardsContainer" Height="196" RenderTransformOrigin="0.502,0.417">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="280" ItemHeight="150" Margin="10"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
    BorderBrush="#e5e7eb"
    BorderThickness="1"
    CornerRadius="8"
    Margin="5"
    Padding="18"
    Width="260"
    Height="140"
    Cursor="Hand"
    MouseLeftButtonUp="Card_Click">

                                   
                                    <Border.Style>
                                        <Style TargetType="Border">
                                           
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                        
                                                        <GradientStop Color="#FFF5F6F8" Offset="1"/>
                                                       
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="BorderBrush" Value="#e5e7eb"/>
                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Setter.Value>
                                            </Setter>

                                           
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#FFF9FAFB" Offset="0"/>
                                                                <GradientStop Color="#FFEFF1F3" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter Property="BorderBrush" Value="#9CA3AF"/>
           
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>


                                    <StackPanel>
                                        <TextBlock Text="{Binding SearchTerm}"
                   FontWeight="Bold"
                   FontSize="14"
                   Margin="0,0,0,10"/>

                                        <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <Border CornerRadius="10" Padding="6,2" Margin="0,0,0,5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFF3F4F6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                <Setter Property="Background" Value="#FFFBEEEE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                <Setter Property="Background" Value="#FFF3F9F5"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                <Setter Property="Background" Value="#FFFDF6E7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <icons:MaterialIcon Width="16" Height="16" Margin="0,0,6,0">
                                                        <icons:MaterialIcon.Style>
                                                            <Style TargetType="icons:MaterialIcon">
                                                                <Setter Property="Kind" Value="ClockOutline"/>
                                                                <Setter Property="Foreground" Value="#9CA3AF"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                        <Setter Property="Kind" Value="ErrorOutline"/>
                                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                        <Setter Property="Kind" Value="CheckCircle"/>
                                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Kind" Value="Autorenew"/>
                                                                        <Setter Property="Foreground" Value="#EAB308"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </icons:MaterialIcon.Style>
                                                    </icons:MaterialIcon>

                                                    <TextBlock Text="{Binding Status}"
                               FontWeight="Bold"
                               FontSize="11"
                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#6b7280"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Success">
                                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Foreground" Value="#EAB308"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                     
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <icons:MaterialIcon Kind="CalendarOutline"
                                Width="14"
                                Height="14"
                                Margin="0,0,6,0"
                                Foreground="#6b7280"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}"
                       FontSize="12"
                       Foreground="#6b7280"/>
                                        </StackPanel>

                                       
                                        <StackPanel Orientation="Horizontal">
                                            <icons:MaterialIcon Kind="PeopleOutline"
                                Width="14"
                                Height="14"
                                Margin="0,0,6,0"
                                Foreground="#6b7280"/>
                                            <TextBlock Text="{Binding TotalLeads, StringFormat='{}{0} leads'}"
                       FontSize="12"
                       Foreground="#6b7280"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </ScrollViewer>
            </Grid>


            <Grid Grid.Row="1" Margin="30" Visibility="Hidden" x:Name="itemsTable">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

              
                <Border Grid.Row="0" 
                        Background="White" 
                        CornerRadius="12" 
                        Padding="20"
                        Margin="0,0,0,20"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <icons:MaterialIcon Kind="DatabaseSearch" 
                        Style="{StaticResource DefaultMaterialIcon}"/>
                            <TextBlock x:Name="txtResultCount" 
               Text="0 resultados encontrados" 
               Foreground="#5B7C99"
               FontWeight="SemiBold"
               FontSize="15"
               VerticalAlignment="Center"/>
                        </StackPanel>


                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButton}"
                                Click="BtnExport_Click"
                                Margin="0,0,10,0"
                                Padding="16,8">
                                <StackPanel Orientation="Horizontal">
                                    <icons:MaterialIcon Kind="FileExport" Style="{StaticResource DefaultMaterialIcon}"/>
                                    <TextBlock Text="Exportar CSV" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SecondaryButton}"
                                Click="BtnClear_Click"
                                Padding="16,8">
                                <StackPanel Orientation="Horizontal">
                                    <icons:MaterialIcon Kind="DeleteSweepOutline" Style="{StaticResource DefaultMaterialIcon}"/>
                                    <TextBlock Text="Limpar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>

                
                <Border Grid.Row="1" 
                        Background="White" 
                        CornerRadius="12" 
                        Padding="0"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        
                        <Border Grid.Row="0" Padding="20,15" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock x:Name="txtStatus" 
                                           Text="Status: Aguardando busca..." 
                                           Foreground="#666666"
                                           FontSize="13"
                                           Margin="0,0,0,10"/>
                                <ProgressBar x:Name="progressBar" 
                                             Height="4" 
                                             Value="0" 
                                             Foreground="#5B7C99" 
                                             Background="#F0F0F0"
                                             BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                       
                        <DataGrid x:Name="dgResults"
                                  Grid.Row="1"
                                  Background="White" 
                                  Foreground="#333333" 
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  RowBackground="White"
                                  AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0"
                                  FontFamily="Segoe UI"
                                  FontSize="13"
                                  Margin="0">

                            <DataGrid.Resources>
                                
                                <Style TargetType="ScrollBar">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Width" Value="8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid>
                                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Border Background="#D0D0D0" 
                                                                                CornerRadius="4"
                                                                                Margin="2,0"/>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="#B0B0B0"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FAFAFA"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="20,15"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="20,12"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E8F4FF"/>
                                            <Setter Property="Foreground" Value="#333333"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome do Local" 
                                                    Binding="{Binding Name}" 
                                                    Width="280"/>
                                <DataGridTextColumn Header="Endereço" 
                                                    Binding="{Binding Address}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Telefone" 
                                                    Binding="{Binding Phone}" 
                                                    Width="140"/>
                                <DataGridTextColumn Header="Avaliação" 
                                                    Binding="{Binding Rating}" 
                                                    Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

      
        <Grid x:Name="modalOverlay" 
              Background="#80000000" 
              Visibility="Collapsed"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <Border Background="White" 
                    Width="480" 
                    MaxHeight="540"
                    CornerRadius="12"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1">

                <Grid Margin="25" UseLayoutRounding="True" SnapsToDevicePixels="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                   
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <Grid Width="36" Height="36" Margin="0,0,10,0">

                                <Ellipse Fill="#E8F4FF" />

                                <icons:MaterialIcon Kind="Magnify"
                            Width="18"
                            Height="18"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Foreground="#5B7C99"/>
                            </Grid>

                            
                            <TextBlock Text="Parâmetros de Busca"
               FontSize="18"
               FontWeight="SemiBold"
               Foreground="#1A1A1A"
               VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button
                               
                                Width="32" 
                                Height="32"
                                FontSize="12"
                                HorizontalAlignment="Right"
                                Background="#F5F5F5"
                                BorderThickness="0"
                                Foreground="#666666"
                                Cursor="Hand"
                                Click="BtnCloseModal_Click">
                            <icons:MaterialIcon Kind="Close" 
                        Width="16" Height="16" 
                        Foreground="#666666"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E5E5E5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                   
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto" 
                                  Margin="0,0,-12,0" 
                                  Padding="0,0,12,0"
                                  UseLayoutRounding="True">
                        <StackPanel>
                            
                            <StackPanel Margin="0,0,0,18">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <icons:MaterialIcon Kind="TextBoxSearchOutline"
                                        Style="{StaticResource DefaultMaterialIcon}"/>
                                    <TextBlock Text="Termos de Busca" 
                                        Foreground="#1A1A1A" 
                                        FontWeight="SemiBold" 
                                        FontSize="13"/>
                                    <TextBlock Text=" *" Foreground="#E74C3C" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                                <TextBox x:Name="txtModalSearchTerms" 
                                         Style="{StaticResource MultiLineTextBox}"
                                         Height="85"
                                         FontSize="13"
                                         Foreground="#666666"
                                         Text="ex: restaurante, dentista, oficina&#x0a;ou insira um por linha"/>
                            </StackPanel>

                           
                            <StackPanel Margin="0,0,0,18">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <icons:MaterialIcon Kind="MapMarker"
                                        Style="{StaticResource DefaultMaterialIcon}"/>
                                    <TextBlock Text="Localização" 
                                        Foreground="#1A1A1A" 
                                        FontWeight="SemiBold" 
                                        FontSize="13"/>
                                    <TextBlock Text=" *" Foreground="#E74C3C" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                                <TextBox x:Name="txtModalLocation" 
                                         Style="{StaticResource ModernTextBox}"
                                         FontSize="13"
                                         Foreground="#666666"
                                         Text="ex: São Paulo, SP"/>
                            </StackPanel>

                           
                            <StackPanel Margin="0,0,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <icons:MaterialIcon Kind="FileUploadOutline"
                                        Style="{StaticResource DefaultMaterialIcon}"/>
                                    <TextBlock Text="Ou Carregar Arquivo" 
                                        Foreground="#1A1A1A" 
                                        FontWeight="SemiBold" 
                                        FontSize="13"/>
                                </StackPanel>
                                <Border BorderBrush="#D0D0D0" 
                                        BorderThickness="1.5" 
                                        CornerRadius="8"
                                        Background="#FAFAFA"
                                        Height="90"
                                        UseLayoutRounding="True">

                                    <Button x:Name="btnUploadFile"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="BtnUploadFile_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid Background="Transparent">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <icons:MaterialIcon Kind="Upload"
                                                            Width="28"
                                                            Height="28"
                                                            Foreground="#999999"
                                                            HorizontalAlignment="Center"
                                                            Margin="0,0,0,6"/>
                                                        <TextBlock Text="Clique para carregar .txt" 
                                                            Foreground="#666666"
                                                            FontSize="12"
                                                            HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Border>
                                <TextBlock x:Name="txtFileName" 
                                           Text="" 
                                           Foreground="#666666"
                                           FontSize="11"
                                           Margin="0,6,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                   
                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <Button HorizontalAlignment="Stretch"
                            Height="42"
                            FontSize="14"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnStartExtraction_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <icons:MaterialIcon Kind="PlayCircleOutline" 
                                    Style="{StaticResource DefaultMaterialIcon}"/>
                                <TextBlock Text="Iniciar Extração" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>