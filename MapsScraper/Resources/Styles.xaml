    <Style x:Key="DefaultIcon" TargetType="{x:Type Path}">
        <Setter Property="Width" Value="13" />
        <Setter Property="Height" Value="13" />
        <Setter Property="Fill" Value="#5B7C99" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>
    
    <Style x:Key="PathStatusIconStyle" TargetType="{x:Type Path}">
        <Setter Property="Width" Value="13" />
        <Setter Property="Height" Value="13" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <RotateTransform Angle="0" />
            </Setter.Value>
        </Setter>

        <Setter Property="Data" Value="{StaticResource ClockIconGeometry}" />
        <Setter Property="Fill" Value="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />

        <Style.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="Failed">
                <Setter Property="Data" Value="{StaticResource ErrorIconGeometry}" />
            </DataTrigger>

            <DataTrigger Binding="{Binding Status}" Value="Completed">
                <Setter Property="Data" Value="{StaticResource CheckIconGeometry}" />
            </DataTrigger>

            <DataTrigger Binding="{Binding Status}" Value="Running">
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="SpinStoryboard">
                        <Storyboard>
                            <DoubleAnimation
                                RepeatBehavior="Forever"
                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                From="0"
                                To="360"
                                Duration="0:0:1" />
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>

                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="SpinStoryboard" />
                </DataTrigger.ExitActions>
                <Setter Property="Data" Value="{StaticResource RotateIconGeometry}" />
            </DataTrigger>

        </Style.Triggers>
    </Style>
</ResourceDictionary>